<Window x:Class="CleanerControlApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CleanerControlApp"
        mc:Ignorable="d"
        Title="清洗機" Height="1080" Width="1920"
        WindowStartupLocation="Manual" Left="0" Top="0"
        WindowState="Maximized"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title Bar -->
            <RowDefinition Height="*"/>
            <!-- Content -->
            <RowDefinition Height="Auto"/>
            <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Title Bar with user box +5 boxes/buttons -->
        <Border Grid.Row="0" Background="#FF2D2D30" Padding="10" MinHeight="96">
            <DockPanel LastChildFill="False">
                <!-- User info box on the left -->
                <Border DockPanel.Dock="Left" Background="#FF3A3A3A" Padding="8" Margin="0,0,8,0" CornerRadius="4" Height="124">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Orientation="Vertical" Margin="0,0,8,0" VerticalAlignment="Center">
                            <TextBlock x:Name="CurrentUserNameText" Text="帳號: -" Foreground="White" FontWeight="Bold" FontSize="18"/>
                            <TextBlock x:Name="CurrentUserRoleText" Text="權限: -" Foreground="White" FontSize="18"/>
                            <TextBlock x:Name="CurrentRecipeText" Text="配方: -" Foreground="White" FontSize="18"/>
                            <Button x:Name="BtnChangeRecipe" Content="變更" Width="80" Height="48" Margin="8,0,0,0" Click="BtnChangeRecipe_Click" FontSize="20" />
                        </StackPanel>
                        <StackPanel Orientation="Vertical" Margin="6,0,0,0">
                            <Button x:Name="LogoutButton" FontSize="20" Content="登出" Padding="10,8" Height="50" Click="LogoutButton_Click"/>
                            <Button x:Name="CloseButton" FontSize="20" Content="關閉" Padding="10,8" Height="50" Margin="0,6,0,0" Click="CloseButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Right-side compact status box with three vertical indicators -->
                <!-- moved to be left-docked and placed before the nav buttons so it sits left of Home -->
                <Border DockPanel.Dock="Left" Background="#FF3A3A3A" Padding="8" Margin="0,0,8,0" CornerRadius="4" VerticalAlignment="Center">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Auto indicator -->
                        <Border x:Name="AutoIndicator" Width="120" Height="28" Background="#FFB0B0B0" CornerRadius="4" Margin="0,4">
                            <TextBlock Text="自動" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                        <!-- Warning indicator -->
                        <Border x:Name="WarningIndicator" Width="120" Height="28" Background="#FFB0B0B0" CornerRadius="4" Margin="0,4">
                            <TextBlock Text="警告" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                        <!-- Alarm indicator -->
                        <Border x:Name="AlarmIndicator" Width="120" Height="28" Background="#FFB0B0B0" CornerRadius="4" Margin="0,4">
                            <TextBlock Text="錯誤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Border>

                <UniformGrid Columns="8" Height="116" Width="1024">
                    <Button x:Name="BtnHome" FontSize="20" Content="主畫面" Margin="0,10,0,10" Padding="12,10" Click="BtnHome_Click" Width="103" />
                    <Button x:Name="BtnManual" FontSize="20" Content="手動操作" Margin="0,10,0,10" Padding="12,10" Click="BtnManual_Click" Width="105" />
                    <Button x:Name="BtnIO" FontSize="20" Content="IO" Margin="0,10,0,10" Padding="12,10" Click="BtnIO_Click" Width="107" />
                    <Button x:Name="BtnAlarm" FontSize="20" Content="Alarm" Margin="0,10,0,10" Padding="12,10" Click="BtnAlarm_Click" Width="107" />
                    <Button x:Name="BtnInfo" FontSize="20" Content="資訊" Margin="0,10,0,10" Padding="12,10" Click="BtnInfo_Click" Width="109" />
                    <Button x:Name="BtnSetting" FontSize="20" Content="設定" Margin="0,10,0,10" Padding="12,10" Click="BtnSetting_Click" Width="111" />
                    <Button x:Name="BtnUser" FontSize="20" Content="使用者管理" Margin="0,10,0,10" Padding="12,10" Click="BtnUser_Click" Width="130" />
                    <Button x:Name="BtnDeveloper" FontSize="20" Content="開發畫面" Margin="0,10,0,10" Padding="12,10" Click="BtnDeveloper_Click" Width="113" />
                </UniformGrid>

            </DockPanel>
        </Border>

        <!-- Main content area for switching modules -->
        <Border Grid.Row="1" Background="#FFF" Padding="8">
            <ContentControl x:Name="MainContent" />
        </Border>

        <!-- Status bar at bottom -->
        <StatusBar Grid.Row="2" Background="#FFEEEEEE">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="VersionTextBlock" Text="Version"/>
            </StatusBarItem>
            <!-- Additional status items can be added here -->
        </StatusBar>

    </Grid>
</Window>
