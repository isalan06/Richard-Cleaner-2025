<UserControl x:Class="CleanerControlApp.Vision.Template.Template_System"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
 xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
 xmlns:sys="clr-namespace:CleanerControlApp.Vision.SystemTemplate"
 mc:Ignorable="d" 
 d:DesignHeight="450" d:DesignWidth="800">
 <Grid>
 <!-- Container canvas that hosts the system line control -->
 <Canvas x:Name="LineHostCanvas" Background="Transparent" Width="800" Height="450">
 <sys:Template_System_Line x:Name="SystemLineControl" Canvas.Left="0" Canvas.Top="0" />
 </Canvas>
 </Grid>
</UserControl>
