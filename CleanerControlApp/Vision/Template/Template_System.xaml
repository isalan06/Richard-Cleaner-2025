<UserControl x:Class="CleanerControlApp.Vision.Template.Template_System"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
 xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
 xmlns:sys="clr-namespace:CleanerControlApp.Vision.SystemTemplate"
 mc:Ignorable="d" 
 d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <!-- Container canvas that hosts the system line control -->
        <Canvas x:Name="LineHostCanvas" Background="Transparent"
 Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=UserControl}}"
 Height="{Binding ActualHeight, RelativeSource={RelativeSource AncestorType=UserControl}}"
 HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <sys:Template_System_Line x:Name="SystemLineControl" Canvas.Left="0" Canvas.Top="0" />

            <!-- Pass buttons for modules -->
            <StackPanel Orientation="Vertical" Canvas.Right="10" Canvas.Top="10" HorizontalAlignment="Right"/>
            <Button x:Name="Btn_Sink_Pass" Content="Pass" Width="80" Height="28" Click="Btn_Sink_Pass_Click" HorizontalAlignment="Left" Canvas.Left="805" Canvas.Top="73" VerticalAlignment="Top" />
            <Button x:Name="Btn_Dry2_Pass" Content="Pass" Width="80" Height="28" Click="Btn_Dry2_Pass_Click" HorizontalAlignment="Left" Canvas.Left="270" Canvas.Top="73" VerticalAlignment="Top" />
            <Button x:Name="Btn_Dry1_Pass" Content="Pass" Width="80" Height="28" Click="Btn_Dry1_Pass_Click" HorizontalAlignment="Left" Canvas.Left="456" Canvas.Top="73" VerticalAlignment="Top" />
            <Button x:Name="Btn_Soaking_Pass" Content="Pass" Width="80" Height="28" Click="Btn_Soaking_Pass_Click" HorizontalAlignment="Left" Canvas.Left="630" Canvas.Top="73" VerticalAlignment="Top" />

        </Canvas>
    </Grid>
</UserControl>
