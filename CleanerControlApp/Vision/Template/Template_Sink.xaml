<UserControl x:Class="CleanerControlApp.Vision.Template.Template_Sink"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
 xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d" 
 d:DesignHeight="752" d:DesignWidth="1229"
 x:Name="RootControl">

    <Grid>
        <Canvas x:Name="MainCanvas" Background="Transparent">
            <!-- 放置元素至此 Canvas 中 -->

            <!-- Embed Template INV1 as UserControl -->
            <local:Tempate_INV_1 Canvas.Left="554" Canvas.Top="353" Width="315" Height="201" />

            <!-- Embed Template Motor3 as UserControl -->
            <local:Template_Motor_3 Canvas.Left="46" Canvas.Top="26" Width="464" Height="292" Canvas.ZIndex="100" />

            <!-- Embed Template Tank Sink as UserControl -->
            <local:Template_Tank_Sink Canvas.Left="399" Width="150" Height="220" HorizontalAlignment="Left" VerticalAlignment="Center" Canvas.ZIndex="20" />
            <Border Canvas.Left="594" Canvas.Top="438" Width="40" Height="32" BorderBrush="Gray" BorderThickness="1" CornerRadius="3" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Act, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#FF0000"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Image Source="/Pictures/TC.png" Stretch="Uniform"/>
            </Border>
            <Border Canvas.Left="546" Canvas.Top="431" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding HighTC, ElementName=RootControl}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HighTC, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#7CFC00"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="TC-4 H" FontSize="10" Foreground="Black"/>

            </Border>
            <Border BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding LowTC, ElementName=RootControl}" HorizontalAlignment="Center" Height="23" Canvas.Left="546" Canvas.Top="456" VerticalAlignment="Top" Width="43">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LowTC, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#7CFC00"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="TC-4 L" FontSize="10" Foreground="Black"/>

            </Border>
            <TextBlock Text="{Binding PV, StringFormat=\{0:F2\}}" FontSize="20" Foreground="Blue" TextAlignment="Center" Width="76" Height="25" HorizontalAlignment="Left" Canvas.Left="547" Canvas.Top="484" VerticalAlignment="Center"/>
            <TextBlock Text="kg/cm2" FontSize="20" Foreground="#333333" TextAlignment="Center" Width="74" Height="25" HorizontalAlignment="Left" Canvas.Left="554" Canvas.Top="514" VerticalAlignment="Center"/>

            <Button Canvas.Left="764" Canvas.Top="128" Width="120" Height="60" FontSize="18" Content="開啟上蓋" Click="OpenCover_Click" Background="#ADD8E6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button Canvas.Left="904" Canvas.Top="128" Width="120" Height="60" FontSize="18" Content="關閉上蓋" Click="CloseCover_Click" Background="#ADD8E6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="開始沖水" Click="OpenPressure_Click" Background="#ADD8E6" Height="60" Canvas.Left="764" Canvas.Top="209" VerticalAlignment="Top" Width="121"/>
            <Button FontSize="18" Content="停止沖水" Click="ClosePressure_Click" Background="#ADD8E6" Height="60" Canvas.Left="904" Canvas.Top="209" VerticalAlignment="Top" Width="121"/>
            <Button FontSize="18" Content="開啟風刀" Click="OpenAir_Click" Background="#ADD8E6" Height="60" Canvas.Left="764" Canvas.Top="288" VerticalAlignment="Top" Width="120"/>
            <Button FontSize="18" Content="關閉風刀" Click="CloseAir_Click" Background="#ADD8E6" Height="60" Canvas.Left="904" Canvas.Top="288" VerticalAlignment="Top" Width="121"/>
            <Button FontSize="18" Content="錯誤重置" Click="ResetAlarm_Click" Background="#ADD8E6" Height="60" Width="121" HorizontalAlignment="Left" Canvas.Left="904" Canvas.Top="376" VerticalAlignment="Center"/>

            <!-- New ComboBox for speed mode -->
            <ComboBox x:Name="cmbSpeedMode" FontSize="18" Canvas.Left="214" Canvas.Top="330" Width="115" Height="30" SelectedIndex="0" SelectedValuePath="Tag" HorizontalAlignment="Left" VerticalAlignment="Center">
                <ComboBoxItem Tag="0">移動速度</ComboBoxItem>
                <ComboBoxItem Tag="1">搖擺速度</ComboBoxItem>
            </ComboBox>
            <TextBlock Text="速度選擇" FontSize="20" Foreground="#333333" TextAlignment="Center" Width="89" Height="25" Canvas.Left="119" Canvas.Top="332" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button x:Name="btnMoveToP1" Canvas.Left="216" Canvas.Top="381" Width="113" Height="48" Content="Move" Click="btnMoveToP1_Click" Background="LightSeaGreen" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button x:Name="btnMoveToP2" Content="Move" Click="btnMoveToP2_Click" Background="LightSeaGreen" Height="48" Canvas.Left="216" Canvas.Top="440" Width="113" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button x:Name="btnMoveToP3" Content="Move" Click="btnMoveToP3_Click" Background="LightSeaGreen" Height="48" Canvas.Left="216" Canvas.Top="501" Width="113" HorizontalAlignment="Left" VerticalAlignment="Center"/>

            <!-- P1 - 上位 indicator with border and background binding to InPos1 -->
            <Border Canvas.Left="88" Canvas.Top="383" Width="120" Height="40" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="4" Padding="4" HorizontalAlignment="Left" VerticalAlignment="Center" ToolTip="P1 - 上位">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InPos1, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#7CFC00" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="P1 - 上位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="Black" />
            </Border>
            <Border Canvas.Left="88" Canvas.Top="444" Width="120" Height="40" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="4" Padding="4" ToolTip="P1 - 上位" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InPos2, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#7CFC00" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="P2 - 中位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="Black" />
            </Border>
            <Border Canvas.Left="88" Canvas.Top="505" Width="120" Height="40" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="4" Padding="4" ToolTip="P1 - 上位" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InPos3, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="#7CFC00" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="P3 - 下位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" Foreground="Black" />
            </Border>
            <Button x:Name="btnTeachP1" Content="Teach" Click="btnTeachP1_Click" Background="LightSeaGreen" Height="48" Canvas.Left="350" Canvas.Top="381" Width="113" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button x:Name="btnTeachP2" Content="Teach" Click="btnTeachP2_Click" Background="LightSeaGreen" Height="48" Canvas.Left="350" Canvas.Top="440" Width="113" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            <Button x:Name="btnTeachP3" Content="Teach" Click="btnTeachP3_Click" Background="LightSeaGreen" Height="48" Canvas.Left="350" Canvas.Top="501" Width="113" HorizontalAlignment="Left" VerticalAlignment="Center"/>

        </Canvas>
    </Grid>
</UserControl>
