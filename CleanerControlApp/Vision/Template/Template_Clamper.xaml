<UserControl x:Class="CleanerControlApp.Vision.Template.Template_Clamper"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="RootControl">
    <Grid>
        <Canvas>
            <!-- Embed Clamper image from project's Pictures folder. Adjust Canvas.Left/Top/Width/Height as needed -->
            <Image Source="pack://application:,,,/CleanerControlApp;component/Pictures/Clamper.png"
                   Canvas.Left="130" Canvas.Top="87"
                   Width="200" Height="200"
                   Stretch="Uniform" />
            <Border Canvas.Left="208" Canvas.Top="106" Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="3" Padding="4" Height="31" Width="44" HorizontalAlignment="Left" VerticalAlignment="Top">

                <TextBlock Text="夾爪" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="240" Canvas.Top="37" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_ClamperFOpen, ElementName=RootControl}" Width="92" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_ClamperFOpen, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X32 - 前夾爪開" FontSize="12" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="214" Canvas.Top="37" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_ClamperFClose, ElementName=RootControl}" Width="92" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_ClamperFClose, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X33 - 前夾爪關" FontSize="12" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="128" Canvas.Top="37" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_ClamperBOpen, ElementName=RootControl}" Width="92" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_ClamperBOpen, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X34 - 後夾爪開" FontSize="12" Foreground="Black"/>
            </Border>
            <Border BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_ClamperBClose, ElementName=RootControl}" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" Height="25" Canvas.Left="155" Canvas.Top="37" VerticalAlignment="Center" Width="92">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_ClamperBClose, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X35 - 後夾爪關" FontSize="12" Foreground="Black"/>
            </Border>
            <Border BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_Exist1, ElementName=RootControl}" RenderTransformOrigin="0.5,0.5" HorizontalAlignment="Left" Height="25" Canvas.Left="247" Canvas.Top="142" VerticalAlignment="Top" Width="72">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_Exist1, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X30 - 在席1" FontSize="12" Foreground="Black"/>
            </Border>
            <Border BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Sensor_Exist2, ElementName=RootControl}" RenderTransformOrigin="0.5,0.5" Height="25" Canvas.Left="137" Canvas.Top="141" Width="72" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="90"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Sensor_Exist2, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="X31 - 在席2" FontSize="12" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="282" Canvas.Top="240" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding ClamperOpen, ElementName=RootControl}" Width="82" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClamperOpen, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Y40 - 夾爪開" FontSize="12" Foreground="Black" />

            </Border>
            <Border Canvas.Left="189" Canvas.Top="282" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding ClamperClose, ElementName=RootControl}" Width="82" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ClamperClose, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Y41 - 夾爪關" FontSize="12" Foreground="Black" />

            </Border>
        </Canvas>
    </Grid>
</UserControl>
