<UserControl x:Class="CleanerControlApp.Vision.Template.Template_SoakingTank"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
 xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d" 
 d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="0,0,-337,-256">
        <Canvas x:Name="MainCanvas" Background="Transparent" Margin="0,0,-205,-218">
            <!-- Embed motor and soaking tank templates -->
            <local:Template_Motor_4 x:Name="MotorTemplate" Canvas.Left="26" Canvas.Top="10" />
            <local:Template_Tank_Soaking x:Name="SoakingTankTemplate" Canvas.Left="451" />
            <Button FontSize="18" Content="開啟上蓋" Click="OpenCover_Click" Background="#ADD8E6" Height="60" Canvas.Left="868" Canvas.Top="119" Width="120"/>
            <Button Canvas.Left="1012" Canvas.Top="119" Width="120" Height="60" FontSize="18" Content="關閉上蓋" Click="CloseCover_Click" Background="#ADD8E6" HorizontalAlignment="Left" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="開啟風刀" Click="OpenAir_Click" Background="#ADD8E6" Height="60" Canvas.Left="868" Canvas.Top="184" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="關閉風刀" Click="CloseAir_Click" Background="#ADD8E6" Height="60" Canvas.Left="1012" Canvas.Top="184" Width="121" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="開啟注水" Click="OpenWaterIn_Click" Background="#ADD8E6" Height="60" Canvas.Left="868" Canvas.Top="249" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="關閉注水" Click="CloseWaterIn_Click" Background="#ADD8E6" Height="60" Canvas.Left="1012" Canvas.Top="249" Width="121" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="開啟超音波" Click="OpenUltrasonic_Click" Background="#ADD8E6" Height="60" Canvas.Left="868" Canvas.Top="314" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="關閉超音波" Click="CloseUltrasonic_Click" Background="#ADD8E6" Height="60" Canvas.Left="1012" Canvas.Top="314" Width="121" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="開啟排水" Click="OpenWaterOut_Click" Background="#ADD8E6" Height="60" Canvas.Left="868" Canvas.Top="379" Width="120" HorizontalAlignment="Center" VerticalAlignment="Top"/>
            <Button FontSize="18" Content="關閉排水" Click="CloseWaterOut_Click" Background="#ADD8E6" Height="60" Canvas.Left="1012" Canvas.Top="379" Width="121" HorizontalAlignment="Center" VerticalAlignment="Top"/>
        </Canvas>
    </Grid>
</UserControl>
