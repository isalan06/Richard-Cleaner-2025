<UserControl x:Class="CleanerControlApp.Vision.Template.Template_Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
             xmlns:sys="clr-namespace:CleanerControlApp.Vision.SystemTemplate"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" x:Name="RootControl">
    <Grid>
        <!-- Container canvas that hosts the system line control -->
        <Canvas x:Name="LineHostCanvas" Background="Transparent"
         HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <sys:Template_System_Line x:Name="SystemLineControl" Canvas.Left="0" Canvas.Top="20" HorizontalAlignment="Left" VerticalAlignment="Center"
 Width="{Binding ActualWidth, ElementName=LineHostCanvas}" />
        </Canvas>
    </Grid>
</UserControl>
