<UserControl x:Class="CleanerControlApp.Vision.Template.Template_Motor_4"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
 xmlns:local="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d" 
 d:DesignHeight="450" d:DesignWidth="800"
 x:Name="RootControl">

    <Grid>
        <Canvas x:Name="MainCanvasMotor3"
 Background="Transparent"
 Width="464"
 Height="292"
 Canvas.Left="0"
 Canvas.Top="0"
 HorizontalAlignment="Left"
 VerticalAlignment="Top"
 Margin="0">

            <!-- Motor image at (0,0) -->
            <Image x:Name="MotorImage"
 Canvas.Left="210"
 Canvas.Top="66"
 Width="93"
 Height="86"
 Stretch="Uniform"
 Source="/CleanerControlApp;component/Pictures/Motor.png" HorizontalAlignment="Left" VerticalAlignment="Center" />
            <Border Canvas.Left="166" Canvas.Top="30" Background="White" BorderBrush="Black" BorderThickness="1" CornerRadius="3" Padding="4" Height="31" Width="102" HorizontalAlignment="Center" VerticalAlignment="Top">

                <TextBlock Text="馬達-4" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="132" Canvas.Top="65" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding LimitN, ElementName=RootControl}" HorizontalAlignment="Center" VerticalAlignment="Center" Width="60">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LimitN, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Limit -" FontSize="16" Foreground="Black" />

            </Border>
            <Border Canvas.Left="132" Canvas.Top="135" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding LimitP, ElementName=RootControl}" Width="60" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding LimitP, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Limit +" FontSize="16" Foreground="Black"/>
            </Border>
            <Border Canvas.Left="132" Canvas.Top="100" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding ServoOn, ElementName=RootControl}" Width="60" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ServoOn, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Servo" FontSize="16" Foreground="Black"/>
            </Border>

            <!-- Position display below MotorImage -->
            <TextBlock x:Name="txtPositionValue" Canvas.Left="170" Canvas.Top="169" Text="0.00" FontSize="20" Foreground="Blue" HorizontalAlignment="Left" VerticalAlignment="Center" Width="80" />

            <!-- Jog speed selector -->
            <TextBlock Canvas.Left="312" Canvas.Top="27" Text="Jog速率:" FontSize="20" Foreground="Black" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <ComboBox x:Name="cmbJogSpeed"  FontSize="20" Canvas.Left="312" Canvas.Top="57" Width="120" Height="32" SelectedIndex="0" SelectedValuePath="Tag" HorizontalAlignment="Left" VerticalAlignment="Top">
                <ComboBoxItem Tag="0">Jog低速</ComboBoxItem>
                <ComboBoxItem Tag="1">Jog中速</ComboBoxItem>
                <ComboBoxItem Tag="2">Jog高速</ComboBoxItem>
            </ComboBox>

            <!-- Jog buttons -->
            <Button x:Name="btnJogMinus" Tag="1" Canvas.Left="312" Canvas.Top="104" Width="114" Height="48" Content="JOG -" Background="Aquamarine"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown" 
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20"/>
            <Button x:Name="btnJogPlus" Tag="0" Canvas.Left="312" Canvas.Top="157" Width="114" Height="48" Content="JOG +" Background="Aquamarine"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown" 
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" HorizontalAlignment="Left" VerticalAlignment="Center" FontSize="20"/>
            <TextBlock Canvas.Left="60" Canvas.Top="169" Text="位置(mm):" FontSize="20" Foreground="Black" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <Border Canvas.Left="4" Canvas.Top="65" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Alarm, ElementName=RootControl}" Width="60" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Alarm, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Alarm" FontSize="16" Foreground="Black" TextAlignment="Center"/>

            </Border>
            <Border Canvas.Left="68" Canvas.Top="65" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Home, ElementName=RootControl}" Width="60" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Home, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Home" FontSize="16" Foreground="Black" TextAlignment="Center"/>
            </Border>
            <Border Canvas.Left="4" Canvas.Top="100" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Busy, ElementName=RootControl}" Width="60" HorizontalAlignment="Center" VerticalAlignment="Top">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Busy, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Red"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Busy" FontSize="16" Foreground="Black" TextAlignment="Center"/>

            </Border>

            <!-- Control buttons placed at bottom -->
            <Button x:Name="btnServoOn" FontSize="20" Canvas.Left="29" Canvas.Top="225" Width="114" Height="48" Content="Servo On" Click="btnServoOn_Click" HorizontalAlignment="Left" VerticalAlignment="Top" Background="LightSeaGreen" />
            <Button x:Name="btnHome" FontSize="20" Canvas.Left="166" Canvas.Top="225" Width="113" Height="48" Content="Home" Click="btnHome_Click" HorizontalAlignment="Left" VerticalAlignment="Center" Background="LightSeaGreen"/>
            <Button x:Name="btnStop" FontSize="20" Canvas.Left="312" Canvas.Top="225" Width="114" Height="48" Content="Stop" Click="btnStop_Click" Background="LightSeaGreen"/>

            <!-- Idle indicator moved inside Canvas so it is visible when embedded -->
            <Border Canvas.Left="68" Canvas.Top="100" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="3" Padding="4" ToolTip="{Binding Idle, ElementName=RootControl}" Width="60">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Background" Value="#FFFFFF"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Idle, ElementName=RootControl}" Value="True">
                                <Setter Property="Background" Value="Lime"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Idle" FontSize="16" Foreground="Black" TextAlignment="Center"/>
            </Border>

        </Canvas>

    </Grid>
</UserControl>
