<UserControl x:Class="CleanerControlApp.Vision.Developer.Module.DevModuleShuttleView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:tpl="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d"
 HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
 <Grid Background="White">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>

 <!-- Top row: title on left, controls also on left -->
 <Grid Grid.Row="0" Margin="10">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="*" />
 </Grid.ColumnDefinitions>

 <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
 <TextBlock Text="Dev Module Shuttle View" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" />
 <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
 <Button x:Name="Btn_Init" Content="&#x521D;&#x59CB;" Width="80" Height="26" Margin="6,0,0,0" Click="Btn_Init_Click" />
 <Button x:Name="Btn_Auto" Content="&#x81EA;&#x52D5;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Auto_Click" />
 <Button x:Name="Btn_Stop" Content="&#x505C;&#x6B62;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Stop_Click" />
 <Button x:Name="Btn_Pause" Content="&#x66AB;&#x505C;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Pause_Click" />
 <Button x:Name="Btn_AlarmStop" Content="&#x932F;&#x8AA4;&#x505C;&#x6B62;" Width="80" Height="26" Margin="6,0,0,0" Click="Btn_AlarmStop_Click" />
 <!-- developer buttons -->
 <Button x:Name="Btn_MotorPass" Content="&#x99AC;&#x9054; Pass" Width="90" Height="26" Margin="6,0,0,0" Click="Btn_MotorPass_Click" />
 <Button x:Name="Btn_ClamperPass" Content="夾爪 Pass" Width="90" Height="26" Margin="6,0,0,0" Click="Btn_ClamerPass_Click" />
                    <!-- removed OpenClamper/CloseClamper/Pick/Place/Move buttons -->
 </StackPanel>
 </StackPanel>
 </Grid>

 <Canvas x:Name="ShuttleCanvas" Grid.Row="1" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10">
 <!-- Embed Template_Shuttle here -->
 <tpl:Template_Shuttle Canvas.Left="0" Canvas.Top="0" Width="{Binding ActualWidth, ElementName=ShuttleCanvas}" Height="{Binding ActualHeight, ElementName=ShuttleCanvas}" />
 </Canvas>
 </Grid>
</UserControl>