<UserControl x:Class="CleanerControlApp.Vision.Developer.Module.DevModuleHeatingTankView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:tpl="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d"
 HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
 <Grid Background="White">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>

 <!-- Top row: title on left, controls also on left -->
 <Grid Grid.Row="0" Margin="10">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="*" />
 </Grid.ColumnDefinitions>

 <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
 <TextBlock Text="Dev Module Heating Tank View" VerticalAlignment="Center" FontSize="16" FontWeight="Bold" />
 <StackPanel Orientation="Horizontal" Margin="12,0,0,0" VerticalAlignment="Center">
 <Button x:Name="Btn_Init" Content="&#x521D;&#x59CB;" Width="80" Height="26" Margin="6,0,0,0" Click="Btn_Init_Click" />
 <Button x:Name="Btn_Auto" Content="&#x81EA;&#x52D5;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Auto_Click" />
 <Button x:Name="Btn_Stop" Content="&#x505C;&#x6B62;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Stop_Click" />
 <Button x:Name="Btn_Pause" Content="&#x66AB;&#x505C;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_Pause_Click" />
 <Button x:Name="Btn_AlarmStop" Content="&#x932F;&#x8AA4;&#x505C;&#x6B62;" Width="80" Height="26" Margin="6,0,0,0" Click="Btn_AlarmStop_Click" />
 <!-- New simulation buttons -->
 <Button x:Name="Btn_SimTemp" Content="&#x6EAB;&#x5EA6;&#x5207;&#x63DB;" Width="80" Height="26" Margin="6,0,0,0" Click="Btn_SimTemp_Click" />
 <Button x:Name="Btn_SimHigh" Content="&#x9AD8;&#x983B;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_SimHigh_Click" />
 <Button x:Name="Btn_SimLow" Content="&#x4F4E;&#x983B;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_SimLow_Click" />
 <Button x:Name="Btn_SimZero" Content="0&#x983B;" Width="60" Height="26" Margin="6,0,0,0" Click="Btn_SimZero_Click" />
 <Button x:Name="Btn_RequestWater" Content="Request Water" Width="100" Height="26" Margin="6,0,0,0" Click="Btn_RequestWater_Click" />
 </StackPanel>
 </StackPanel>
 </Grid>

 <Canvas x:Name="HeatingTankCanvas" Grid.Row="1" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10">
 <tpl:Template_HeatingTank Canvas.Left="0" Canvas.Top="0" Width="{Binding ActualWidth, ElementName=HeatingTankCanvas}" Height="{Binding ActualHeight, ElementName=HeatingTankCanvas}" />
 </Canvas>
 </Grid>
</UserControl>