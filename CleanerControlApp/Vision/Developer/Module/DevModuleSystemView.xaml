<UserControl x:Class="CleanerControlApp.Vision.Developer.Module.DevModuleSystemView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:template="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d"
 d:DesignHeight="400" d:DesignWidth="600">
 <Grid Background="White" Margin="0,0,-270,-151">
 <TextBlock Text="Dev Module System View" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="10" FontSize="16" FontWeight="Bold"/>
 <Border Margin="10,44,10,152" BorderBrush="Gray" BorderThickness="1" CornerRadius="4" Background="#FFF8F8F8">
            <Grid>
                <!-- Embedded Template_System inside a Canvas -->
                <Canvas Background="Transparent">
                    <template:Template_System Canvas.Left="0" Canvas.Top="0" />
                    <StackPanel Orientation="Vertical" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="10,0,0,66">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="系統 測試各點位 啟動狀態: " FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDryRunStatus" Text="False" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="測試各點位 狀態: " FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock x:Name="txtDryRunStatusString" Text="" FontSize="16" VerticalAlignment="Center" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button x:Name="btnStartDryRun" FontSize="20" Content="啟動測試" Click="BtnStartDryRun_Click" Width="100" Margin="0,0,8,0"/>
                            <Button x:Name="btnStopDryRun" FontSize="20" Content="停止測試" Click="BtnStopDryRun_Click" Width="100" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Button x:Name="btnPassClamperCheckCassette" FontSize="20" Content="自動不檢查卡匣" Click="btnPassClamperCheckCassette_Click" Width="200" Margin="0,0,8,0"/>
                        </StackPanel>
                    </StackPanel>
                </Canvas>
                
            </Grid>
        </Border>

 <!-- Dry run status and controls placed at bottom -->
 
 </Grid>
</UserControl>