 </Border>

 </Grid>

 <!-- Shuttle and Motor parameter boxes (third row) -->
 <Grid Grid.Row="2" Margin="8">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="300" />
 <ColumnDefinition Width="16" />
 <ColumnDefinition Width="300" />
 <ColumnDefinition Width="16" />
 <ColumnDefinition Width="300" />
 <ColumnDefinition />
 </Grid.ColumnDefinitions>

 <!-- Shuttle box -->
 <Border Grid.Column="0" Background="#FFF8F8F8" BorderBrush="#FFBDBDBD" BorderThickness="1" CornerRadius="6" Padding="8" HorizontalAlignment="Left">
 <StackPanel>
