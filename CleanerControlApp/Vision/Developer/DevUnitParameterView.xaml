 </Grid.RowDefinitions>

 <!-- UnitTransfer -->
 <TextBlock Grid.Column="0" Text="UnitTransfer:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtHeatingUnitTransfer" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- SV Low Limit -->
 <TextBlock Grid.Row="1" Grid.Column="0" Text="SV Low Limit:" VerticalAlignment="Center" Margin="4,0,4,0" Height="16" />
 <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtHeatingSVLowLimit" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- SV High Limit -->
 <TextBlock Grid.Row="2" Grid.Column="0" Text="SV High Limit:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtHeatingSVHighLimit" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- PV Low Timeout -->
 <TextBlock Grid.Row="3" Grid.Column="0" Text="PV Low Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtHeatingPVLowTimeout" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- PV High Timeout -->
 <TextBlock Grid.Row="4" Grid.Column="0" Text="PV High Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
