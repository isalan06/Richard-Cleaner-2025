 <Grid>
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="150" />
 <ColumnDefinition />
 </Grid.ColumnDefinitions>
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <!-- Motor UnitTransfer -->
 <RowDefinition Height="Auto" />
 <!-- UnitTransfer -->
 <RowDefinition Height="Auto" />
 <!-- SV Low -->
 <RowDefinition Height="Auto" />
 <!-- SV High -->
 <RowDefinition Height="Auto" />
 <!-- PV Low -->
 <RowDefinition Height="Auto" />
 <!-- PV High -->
 <RowDefinition Height="Auto" />
 <!-- Cover Open -->
 <RowDefinition Height="Auto" />
 <!-- Cover Close -->
 <RowDefinition Height="Auto" />
 <!-- SV Check -->
 <RowDefinition Height="Auto" />
 <!-- ActTime -->
 </Grid.RowDefinitions>

 <!-- Motor UnitTransfer -->
 <TextBlock Grid.Column="0" Text="Motor UnitTransfer:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtSinkMotorUnitTransfer" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- UnitTransfer -->
 <TextBlock Grid.Row="1" Grid.Column="0" Text="UnitTransfer:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSinkUnitTransfer" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- SV Low Limit -->
 <TextBlock Grid.Row="2" Grid.Column="0" Text="SV Low Limit:" VerticalAlignment="Center" Margin="4,0,4,0" Height="16" />
 <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtSinkSVLowLimit" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- SV High Limit -->
 <TextBlock Grid.Row="3" Grid.Column="0" Text="SV High Limit:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtSinkSVHighLimit" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- PV Low Timeout -->
 <TextBlock Grid.Row="4" Grid.Column="0" Text="PV Low Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtSinkPVLowTimeout" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- PV High Timeout -->
 <TextBlock Grid.Row="5" Grid.Column="0" Text="PV High Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtSinkPVHighTimeout" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- Cover Open Timeout -->
 <TextBlock Grid.Row="6" Grid.Column="0" Text="Cover Open Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="16" />
 <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtSinkCoverOpenTimeout" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- Cover Close Timeout -->
 <TextBlock Grid.Row="7" Grid.Column="0" Text="Cover Close Timeout (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="7" Grid.Column="1" x:Name="TxtSinkCoverCloseTimeout" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- SV Check Offset -->
 <TextBlock Grid.Row="8" Grid.Column="0" Text="SV Check Offset:" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="8" Grid.Column="1" x:Name="TxtSinkSVCheckOffset" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 <!-- ActTime Limit -->
 <TextBlock Grid.Row="9" Grid.Column="0" Text="ActTime Limit (s):" VerticalAlignment="Center" Margin="4,0,4,0" Height="15" />
 <TextBox Grid.Row="9" Grid.Column="1" x:Name="TxtSinkActTimeLimit" Width="120" HorizontalAlignment="Center" Margin="0,4,0,4" />

 </Grid>
 </StackPanel>
 </Border>

 <!-- Heating Tank box (new) -->
 <Border Grid.Row="0" Grid.Column="4" Background="#FFF8F8F8" BorderBrush="#FFBDBDBD" BorderThickness="1" CornerRadius="6" Padding="8" HorizontalAlignment="Left">
 <StackPanel>
 <TextBlock Text="加熱槽參數" FontWeight="Bold" FontSize="14" Margin="0,0,0,6" />
 <Grid>
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="150" />
 <ColumnDefinition />
 </Grid.ColumnDefinitions>
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <!-- UnitTransfer -->
 <RowDefinition Height="Auto" />
 <!-- SV Low -->
 <RowDefinition Height="Auto" />
 <!-- SV High -->
 <RowDefinition Height="Auto" />
 <!-- PV Low -->
 <RowDefinition Height="Auto" />
 <!-- PV High -->
 <RowDefinition Height="Auto" />
 <!-- INV High Timeout -->
