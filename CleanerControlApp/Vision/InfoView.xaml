<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="CleanerControlApp.Vision.InfoView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:log="clr-namespace:CleanerControlApp.Utilities.Log"
 mc:Ignorable="d"
 d:DesignHeight="600" d:DesignWidth="800">
 <UserControl.Resources>
 <ObjectDataProvider x:Key="EmptyLogList" ObjectType="{x:Type log:OperateLog}" MethodName="GetEntriesForDate">
 <ObjectDataProvider.MethodParameters>
 <sys:DateTime xmlns:sys="clr-namespace:System;assembly=mscorlib">0001-01-01T00:00:00</sys:DateTime>
 </ObjectDataProvider.MethodParameters>
 </ObjectDataProvider>
 </UserControl.Resources>
 <Grid Background="White">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="2*" />
 <ColumnDefinition Width="3*" />
 </Grid.ColumnDefinitions>

 <!-- Titles above each bordered panel -->
 <TextBlock Grid.Row="0" Grid.Column="0" Text="&#x7CFB;&#x7D71;&#x8CC7;&#x8A0A;" FontSize="18" FontWeight="Bold" Margin="8" HorizontalAlignment="Center" />
 <TextBlock Grid.Row="0" Grid.Column="1" Text="Log&#x8CC7;&#x8A0A;" FontSize="18" FontWeight="Bold" Margin="8" HorizontalAlignment="Center" />

 <Border Grid.Row="1" Grid.Column="0" Margin="8" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="4" Background="White">
 <ScrollViewer Margin="8" VerticalScrollBarVisibility="Auto">
 <StackPanel>
 <StackPanel x:Name="SystemInfoPanel">
 <TextBlock x:Name="SoftwareVersionText" Text="" TextWrapping="Wrap" FontWeight="SemiBold" />
 <TextBlock x:Name="OSVersionText" Text="" TextWrapping="Wrap" Margin="0,4,0,0" />

 <!-- Communication status header -->
 <TextBlock Text="通訊連線狀態" FontWeight="Bold" Margin="0,8,0,4" />
 <!-- Status list -->
 <StackPanel Orientation="Vertical">
 <!-- One row template: Ellipse + Label -->
 <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
 <Ellipse Width="12" Height="12" Margin="0,0,8,0" Stroke="Black" StrokeThickness="0.5" Fill="{Binding ModbusTcpBrush}" />
 <TextBlock Text="Modbus TCP - PLC - 馬達及DIO控制" VerticalAlignment="Center" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
 <Ellipse Width="12" Height="12" Margin="0,0,8,0" Stroke="Black" StrokeThickness="0.5" Fill="{Binding ModbusRtu1Brush}" />
 <TextBlock Text="Modbus RTU #1 -變頻器#1" VerticalAlignment="Center" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
 <Ellipse Width="12" Height="12" Margin="0,0,8,0" Stroke="Black" StrokeThickness="0.5" Fill="{Binding ModbusRtu2Brush}" />
 <TextBlock Text="Modbus RTU #2 -變頻器#2" VerticalAlignment="Center" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
 <Ellipse Width="12" Height="12" Margin="0,0,8,0" Stroke="Black" StrokeThickness="0.5" Fill="{Binding ModbusRtu3Brush}" />
 <TextBlock Text="Modbus RTU #3 - 溫度控制器" VerticalAlignment="Center" />
 </StackPanel>

 <StackPanel Orientation="Horizontal" Margin="0,2,0,2" VerticalAlignment="Center">
 <Ellipse Width="12" Height="12" Margin="0,0,8,0" Stroke="Black" StrokeThickness="0.5" Fill="{Binding ModbusRtu4Brush}" />
 <TextBlock Text="Modbus RTU #4 - 超音波" VerticalAlignment="Center" />
 </StackPanel>
 </StackPanel>
 </StackPanel>

 <StackPanel Margin="8">
 <Grid>
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="Auto" />
 <ColumnDefinition Width="*" />
 </Grid.ColumnDefinitions>
 <TextBlock Text="各模組資訊" FontWeight="Bold" Margin="0,8,8,4" VerticalAlignment="Center" Grid.Column="0" />
 <ComboBox x:Name="ModuleInfoComboBox" Width="220" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
 <ComboBoxItem Content="系統" IsSelected="True" />
 <ComboBoxItem Content="移載組" />
 <ComboBoxItem Content="沖水槽" />
 <ComboBoxItem Content="浸泡槽" />
 <ComboBoxItem Content="烘乾槽#1" />
 <ComboBoxItem Content="烘乾槽#2" />
 <ComboBoxItem Content="加熱槽" />
 </ComboBox>
 </Grid>

 <RichTextBox x:Name="ModuleInfoRichText" Margin="0,8,0,0" Height="420" IsReadOnly="True">
 <FlowDocument>
 <Paragraph>
 <Run Text="請選擇模組以顯示資訊..." />
 </Paragraph>
 </FlowDocument>
 </RichTextBox>
 </StackPanel>
 </StackPanel>
 </ScrollViewer>
 </Border>

 <Border Grid.Row="1" Grid.Column="1" Margin="8" BorderBrush="#FFCCCCCC" BorderThickness="1" CornerRadius="4" Background="White">
 <Grid>
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 <RowDefinition Height="Auto" />
 </Grid.RowDefinitions>

 <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Top" Grid.Row="0">
 <TextBlock Text="&#x65E5;&#x671F;&#x9078;&#x64C7;" VerticalAlignment="Center" Margin="0,4,8,0" />
 <DatePicker x:Name="dpLogDate" Width="160" CalendarOpened="DpLogDate_CalendarOpened" />
 <Button x:Name="btnLoadLog" Content="讀取" Margin="8,0,0,0" Padding="8,4" Click="BtnLoadLog_Click" />
 <Button x:Name="btnDownload" Content="下載" Margin="8,0,0,0" Padding="8,4" Click="BtnDownload_Click" IsEnabled="False" />
 </StackPanel>

 <Separator Grid.Row="1" Margin="8,0,8,0" />

 <DataGrid x:Name="logGrid" Margin="8" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="2">
 <DataGrid.Columns>
 <DataGridTextColumn Header="&#x6642;&#x9593;" Binding="{Binding Timestamp}" Width="160" />
 <DataGridTextColumn Header="&#x4E8B;&#x4EF6;" Binding="{Binding EventName}" Width="120" />
 <DataGridTextColumn Header="&#x4F7F;&#x7528;&#x8005;" Binding="{Binding UserName}" Width="120" />
 <DataGridTextColumn Header="&#x63CF;&#x8FF0;" Binding="{Binding Description}" Width="*" />
 </DataGrid.Columns>
 </DataGrid>

 <TextBlock x:Name="LogStatusText" Grid.Row="3" Margin="8" Foreground="Gray" FontStyle="Italic" />
 </Grid>
 </Border>

 </Grid>
</UserControl>
