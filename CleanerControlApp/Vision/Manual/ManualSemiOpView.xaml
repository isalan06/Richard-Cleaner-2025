<UserControl x:Class="CleanerControlApp.Vision.Manual.ManualSemiOpView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:template="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d"
 d:DesignHeight="400" d:DesignWidth="600">
 <Grid Background="Transparent">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>

 <Canvas Grid.Row="1" x:Name="SemiOpCanvas" Background="Transparent">
 <!-- 方框 (Border)置於 Canvas 中，內含上方文字 "移載組" -->
 <Border Canvas.Left="20" Canvas.Top="20" Background="#FFF" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
 <Grid>
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="Auto" />
 <RowDefinition Height="Auto" />
 </Grid.RowDefinitions>

 <TextBlock Text="移載組" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0" Grid.Row="0" />

 <!-- 將第二個方框放在第一個方框內，置於標題下方 -->
 <Border Grid.Row="1" Margin="8" Background="#FFF" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
 <Grid>
 <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,6,0,0">
 <TextBlock Text="JOG" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,4,0,6" />

 <!--參考 Template_Motor_1.xaml 的 jog速率 label + combo -->
 <TextBlock Text="Jog速率:" FontSize="16" Foreground="Black" HorizontalAlignment="Left" Margin="8,0,0,2" />
 <ComboBox x:Name="cmbJogSpeed_SemiOp" FontSize="16" Width="140" Height="28" SelectedIndex="0" SelectedValuePath="Tag" HorizontalAlignment="Left" Margin="8,0,0,6">
 <ComboBoxItem Tag="0">Jog低速</ComboBoxItem>
 <ComboBoxItem Tag="1">Jog中速</ComboBoxItem>
 <ComboBoxItem Tag="2">Jog高速</ComboBoxItem>
 </ComboBox>

 <!-- 按鈕區 (3欄)：左 X+, 中 Z- / Z+,右 X- -->
 <Grid Margin="8,6,8,6">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="Auto" />
 <ColumnDefinition Width="Auto" />
 <ColumnDefinition Width="Auto" />
 </Grid.ColumnDefinitions>

 <!-- 左：X Jog + -->
 <Button x:Name="btnXJogPlus" Grid.Column="0" Tag="0,0" Width="80" Height="60" Content="X Jog +" Background="Aquamarine"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown"
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" HorizontalAlignment="Left" FontSize="14" />

 <!-- 中：上下兩個 Z 按鈕 -->
 <StackPanel Grid.Column="1" Orientation="Vertical" Margin="8,0,8,0">
 <Button x:Name="btnZJogMinus" Tag="1,1" Width="80" Height="60" Content="Z Jog -" Background="Aquamarine"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown"
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" FontSize="14" />
 <Button x:Name="btnZJogPlus" Tag="1,0" Width="80" Height="60" Content="Z Jog +" Background="Aquamarine" Margin="0,6,0,0"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown"
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" FontSize="14" />
 </StackPanel>

 <!--右：X Jog - -->
 <Button x:Name="btnXJogMinus" Grid.Column="2" Tag="0,1" Width="80" Height="60" Content="X Jog -" Background="Aquamarine"
 PreviewMouseLeftButtonDown="JogButton_PreviewMouseLeftButtonDown"
 PreviewMouseLeftButtonUp="JogButton_PreviewMouseLeftButtonUp" HorizontalAlignment="Left" FontSize="14" />
 </Grid>

 </StackPanel>
 </Grid>
 </Border>

 <!-- 在移載組方框下方新增另一個方框，內含上方文字 "操作" -->
 <Border Grid.Row="2" Margin="8,8,8,8" Background="#FFF" BorderBrush="Gray" BorderThickness="1" CornerRadius="4">
 <Grid>
 <StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="8">
 <TextBlock Text="操作" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,6" />

 <ComboBox x:Name="cmbSemiPositions" FontSize="14" Margin="4,0,4,8" />

 <!-- 定位 顯示 與 Teach 按鈕 -->
 <Grid Margin="4,6,4,4">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="Auto" />
 <ColumnDefinition Width="8" />
 <ColumnDefinition Width="Auto" />
 </Grid.ColumnDefinitions>

 <!-- 定位 顯示 (背景會在程式碼中更新為 Lime 或 White) -->
 <Border x:Name="bdSemiInPos" Grid.Column="0" Width="120" Height="36" BorderBrush="#2E993E" BorderThickness="1" CornerRadius="4" Padding="4" HorizontalAlignment="Left" VerticalAlignment="Center">
 <TextBlock Text="定位" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14" />
 </Border>

 <!-- Teach 按鈕 -->
 <Button x:Name="btnTeachSemi" Grid.Column="2" Width="100" Height="36" Content="Teach" FontSize="14" Background="LightSeaGreen" Click="btnTeachSemi_Click" />
 </Grid>

 <!-- Pick/Place buttons -->
 <Grid Margin="4,8,4,4">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="*" />
 <ColumnDefinition Width="8" />
 <ColumnDefinition Width="*" />
 </Grid.ColumnDefinitions>
 <Button x:Name="btnPickSemi" Grid.Column="0" Height="36" Content="Pick 程序" FontSize="14" Background="LightSeaGreen" Click="btnPickSemi_Click" />
 <Button x:Name="btnPlaceSemi" Grid.Column="2" Height="36" Content="Place 程序" FontSize="14" Background="LightSeaGreen" Click="btnPlaceSemi_Click" />
 </Grid>
 </StackPanel>
 </Grid>
 </Border>
 </Grid>
 </Border>

 <!--先前在 Canvas 中的外部第二個方框已移入上方的第一個方框 -->
 </Canvas>

 <!-- Top title -->
 <TextBlock Text=" 半自動操作" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,10" />

 </Grid>
</UserControl>
