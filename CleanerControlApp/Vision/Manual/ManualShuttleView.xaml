 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:template="clr-namespace:CleanerControlApp.Vision.Template"
 mc:Ignorable="d" Height="773" Width="1218">
 <Grid Background="Transparent">
 <Grid.RowDefinitions>
