<UserControl x:Class="CleanerControlApp.Vision.AlarmView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:alarm="clr-namespace:CleanerControlApp.Utilities.Alarm"
 mc:Ignorable="d"
 d:DesignHeight="600" d:DesignWidth="800">
 <UserControl.Resources>
 <!-- Call static method GetAllEntries on AlarmManager to obtain the current snapshot -->
 <ObjectDataProvider x:Key="AllAlarms" ObjectType="{x:Type alarm:AlarmManager}" MethodName="GetAllEntries" />
 </UserControl.Resources>
 <Grid Background="White">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="2*" />
 <ColumnDefinition Width="3*" />
 </Grid.ColumnDefinitions>

 <!-- Left panel: 即時警報 -->
 <Border Grid.Column="0" Margin="8" BorderThickness="1" BorderBrush="LightGray" CornerRadius="4" Background="WhiteSmoke">
 <!-- Use internal grid with two rows: top2/3 DataGrid, bottom1/3 explanation -->
 <Grid>
 <Grid.RowDefinitions>
 <RowDefinition Height="2*" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>

 <DockPanel Grid.Row="0">
 <TextBlock Text="即時警報" FontSize="16" FontWeight="Bold" Margin="8" DockPanel.Dock="Top" />
 <!-- DataGrid bound to AlarmManager.GetAllEntries(), rows hidden when IsAlarm is false -->
 <DataGrid x:Name="realTimeGrid" ItemsSource="{Binding Source={StaticResource AllAlarms}}"
 Margin="8"
 AutoGenerateColumns="False"
 IsReadOnly="True"
 SelectionMode="Single"
 SelectionUnit="FullRow"
 SelectionChanged="RealTimeGrid_SelectionChanged">
 <DataGrid.RowStyle>
 <Style TargetType="DataGridRow">
 <Setter Property="Visibility" Value="Collapsed" />
 <Style.Triggers>
 <DataTrigger Binding="{Binding IsAlarm}" Value="True">
 <Setter Property="Visibility" Value="Visible" />
 </DataTrigger>
 </Style.Triggers>
 </Style>
 </DataGrid.RowStyle>
 <DataGrid.Columns>
 <DataGridTextColumn Header="錯誤碼" Binding="{Binding Code}" Width="80" />
 <DataGridTextColumn Header="類別" Binding="{Binding Type}" Width="80" />
 <DataGridTextColumn Header="模組" Binding="{Binding Module}" Width="80" />
 <DataGridTextColumn Header="錯碼敘述" Binding="{Binding Description}" Width="*" />
 </DataGrid.Columns>
 </DataGrid>
 </DockPanel>

 <!-- Bottom area: explanation with query controls above the solution -->
 <Grid Grid.Row="1" Margin="8">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="1*" />

 </Grid.ColumnDefinitions>
 <!-- Left: code input on top, then label and solution textbox -->
 <StackPanel Grid.Column="0" HorizontalAlignment="Stretch">
 <!-- Moved here: code label, input and query button -->
 <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
 <TextBlock Text="錯誤碼:" VerticalAlignment="Center" Margin="0,4,6,0" />
 <TextBox x:Name="txtCodeQuery" Width="120" VerticalAlignment="Center" />
 <Button x:Name="btnQuery" Content="查詢" Margin="8,0,0,0" Padding="8,4" Click="BtnQuery_Click" />
 </StackPanel>
 <TextBlock Text="錯誤說明" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" />
 <TextBox x:Name="txtSolution" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="White" Height="125" HorizontalAlignment="Stretch" />
 </StackPanel>
 <!-- Right: kept empty or reserved for future controls -->
 <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="8,0,0,0">
 <!-- Previously held query controls; now left empty -->
 </StackPanel>
 </Grid>
 </Grid>
 </Border>

 <!-- Right panel: 歷史警報 -->
 <Border Grid.Column="1" Margin="8" BorderThickness="1" BorderBrush="LightGray" CornerRadius="4" Background="WhiteSmoke">
 <Grid>
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>

 <TextBlock Text="歷史警報" FontSize="16" FontWeight="Bold" Margin="8" Grid.Row="0" />
 <!-- Date selection label and DatePicker with Load button -->
 <StackPanel Orientation="Horizontal" Margin="8" VerticalAlignment="Top" Grid.Row="1">
 <TextBlock Text="日期選擇" VerticalAlignment="Center" Margin="0,4,8,0" />
 <DatePicker x:Name="dpHistoryDate" Width="160" CalendarOpened="DpHistoryDate_CalendarOpened" />
 <Button x:Name="btnLoadHistory" Content="讀取" Margin="8,0,0,0" Padding="8,4" Click="BtnLoadHistory_Click" />
 <Button x:Name="btnDownload" Content="下載" Margin="8,0,0,0" Padding="8,4" Click="BtnDownload_Click" IsEnabled="False" />
 </StackPanel>
 <!-- Separator -->
 <Separator Grid.Row="2" Margin="8,0,8,0" />
 <!-- History DataGrid placed below separator -->
 <DataGrid x:Name="historyGrid" Margin="8" AutoGenerateColumns="False" IsReadOnly="True" Grid.Row="2" SelectionChanged="HistoryGrid_SelectionChanged">
 <DataGrid.Columns>
 <DataGridTextColumn Header="錯誤碼" Binding="{Binding AlarmCode}" Width="80" />
 <DataGridTextColumn Header="類別" Binding="{Binding Type}" Width="80" />
 <DataGridTextColumn Header="時間" Binding="{Binding Time}" Width="140" />
 <DataGridTextColumn Header="動作" Binding="{Binding Status}" Width="80" />
 <DataGridTextColumn Header="模組" Binding="{Binding Module}" Width="100" />
 <DataGridTextColumn Header="錯誤描述" Binding="{Binding Description}" Width="*" />
 </DataGrid.Columns>
 </DataGrid>
 </Grid>
 </Border>
 </Grid>
</UserControl>
