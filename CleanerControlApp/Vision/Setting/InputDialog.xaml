<Window x:Class="CleanerControlApp.Vision.SettingViews.InputDialog"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="輸入配方名稱" Height="150" Width="360" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
 <Grid Margin="10">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto" />
 <RowDefinition Height="Auto" />
 <RowDefinition Height="*" />
 </Grid.RowDefinitions>
 <TextBlock Text="請輸入配方名稱:" FontWeight="SemiBold" />
 <TextBox x:Name="TxtName" Grid.Row="1" Margin="0,8,0,8" />
 <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
 <Button x:Name="BtnOk" Content="確認" Width="80" Margin="0,0,8,0" Click="BtnOk_Click" />
 <Button x:Name="BtnCancel" Content="取消" Width="80" Click="BtnCancel_Click" />
 </StackPanel>
 </Grid>
</Window>