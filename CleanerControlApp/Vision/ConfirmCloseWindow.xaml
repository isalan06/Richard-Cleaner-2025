<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CleanerControlApp.Vision.ConfirmCloseWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Confirm" Height="180" Width="420" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="SingleBorderWindow">
 <Grid Margin="16">
 <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
 <TextBlock Text="是否要關閉應用程式?" FontSize="20" TextAlignment="Center" HorizontalAlignment="Center" Margin="0,0,0,16"/>
 <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
 <Button x:Name="BtnConfirm" Content="確認" Width="100" Height="40" Margin="8" Click="BtnConfirm_Click" FontSize="20"/>
 <Button x:Name="BtnCancel" Content="取消" Width="100" Height="40" Margin="8" Click="BtnCancel_Click" FontSize="20"/>
 </StackPanel>
 </StackPanel>
 </Grid>
</Window>